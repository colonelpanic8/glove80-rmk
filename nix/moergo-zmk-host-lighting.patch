         LOG_ERR("Unable to examine EXT_POWER: %d", c_power);
         c_power = 0;
     }
-    int desired_state = state.on || state.status_active;
+    int desired_state = state.on || state.status_active
+#if IS_ENABLED(CONFIG_ZMK_HOST_LIGHTING)
