menuconfig ZMK_MAINTENANCE_RPC
    bool "Secured host maintenance commands"
    depends on ZMK_STUDIO_RPC
    depends on !ZMK_SPLIT || ZMK_SPLIT_ROLE_CENTRAL
    help
      Expose explicitly destructive maintenance operations through ZMK Studio.
      Bootloader entry is restricted to the selected USB endpoint, but does not
      require a physical Studio unlock.

if ZMK_MAINTENANCE_RPC

config ZMK_MAINTENANCE_BOOTLOADER_DELAY_MS
    int "Delay before entering the UF2 bootloader"
    default 250
    range 100 2000
    help
      Allow the Studio response to leave the device before it reboots.

endif
